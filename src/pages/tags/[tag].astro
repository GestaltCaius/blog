---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../config";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags?.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
const sorted = [...posts].sort(
  (a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0),
);
---

<Layout title={`#${tag} — ${SITE.title}`}>
  <main class="max-w-2xl mx-auto px-4 py-10 pb-16">
    <a
      href={`${base}tags/`}
      class="text-sm text-base-content/40 hover:text-base-content transition-colors mb-8 inline-block"
      >← Tags</a
    >
    <h1 class="text-2xl font-bold mb-8">#{tag}</h1>
    {
      sorted.map((post) => (
        <article class="py-6 border-b border-base-200 last:border-0">
          <a href={`${base}${post.id}/`} class="group block">
            <h2 class="font-semibold text-base-content group-hover:underline underline-offset-2 decoration-base-content/30">
              {post.data.title}
            </h2>
            <p class="text-sm text-base-content/60 mt-1">
              {post.data.description}
            </p>
            {post.data.pubDate && (
              <p class="text-xs text-base-content/40 mt-2">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
            )}
          </a>
        </article>
      ))
    }
  </main>
</Layout>
