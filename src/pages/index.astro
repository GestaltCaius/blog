---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../config";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0),
);

const base = import.meta.env.BASE_URL;
---

<Layout title={SITE.title}>
  <main class="max-w-2xl mx-auto px-4 py-10 pb-16">
    {
      posts.map((post) => (
        <article class="py-6 border-b border-base-200 last:border-0">
          <a href={`${base}${post.id}/`} class="group block">
            <h2 class="font-semibold text-base-content group-hover:underline underline-offset-2 decoration-base-content/30">
              {post.data.title}
            </h2>
            <p class="text-sm text-base-content/60 mt-1">
              {post.data.description}
            </p>
          </a>
          <div class="flex flex-wrap gap-3 mt-2 text-xs text-base-content/40">
            {post.data.pubDate && (
              <span>
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </span>
            )}
            {post.data.tags?.map((tag) => (
              <a
                href={`${base}tags/${tag}/`}
                class="hover:text-base-content/70 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </main>
</Layout>
